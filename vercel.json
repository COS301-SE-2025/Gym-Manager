{
  "version": 2,
  "builds": [
    { "src": "services/api/src/index.ts", "use": "@vercel/node" },
    { "src": "apps/web/package.json",     "use": "@vercel/static-build" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "services/api/src/index.ts" },
    { "src": "/(.*)",     "dest": "apps/web/$1" }
  ]
}
